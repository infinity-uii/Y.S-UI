# ============================================================
# Y.S Agent System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Server ---
PORT=8080
HOST=0.0.0.0
WEB_CONCURRENCY=2
SECRET_KEY=change-me-to-a-random-string

# --- Admin Authentication (YS_USER / YS_PASSWORD) ---
YS_USER=admin
YS_PASSWORD=change-me

# --- API Key for OpenAI-compatible endpoint ---
MASTER_API_KEY=

# --- AI Provider Keys (comma-separated for multi-key rotation) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Ollama (default local provider) ---
OLLAMA_BASE=http://localhost:11434

# --- Active Provider/Model (optional overrides) ---
ACTIVE_PROVIDER=groq
ACTIVE_MODEL=

# --- CORS (comma-separated origins, empty = allow all) ---
ALLOWED_ORIGINS=

# --- Rate Limiting ---
RATELIMIT_STORAGE_URL=memory://

# --- File Workspace ---
WORKSPACE_DIR=./workspace

# --- GitHub Integration ---
GITHUB_TOKEN=

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=

# --- MCP Tool Servers (optional, JSON array) ---
MCP_SERVERS=[]

# --- Database (optional, falls back to in-memory) ---
DATABASE_URL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Supabase (optional, for persistent storage) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
