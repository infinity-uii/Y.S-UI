# ============================================================
# Y.S Agent System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=5000
HOST=0.0.0.0
WEB_CONCURRENCY=2

# --- Session Secret (required — any long random string) ---
# On Replit: set this in Secrets as SESSION_SECRET
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- Admin Authentication ---
# Login credentials for the web UI
YS_USER=admin
YS_PASSWORD=change-me-to-a-strong-password

# --- API Gateway Master Key (optional) ---
# Bearer / X-API-Key token for programmatic access to the gateway.
# If unset, only session-authenticated users can call /api/gateway/*.
MASTER_API_KEY=

# --- AI Provider Keys (leave blank for providers you don't use) ---
# At least one provider key is required for AI features.
# Ollama runs locally — no key needed, just set OLLAMA_BASE.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Ollama (local / self-hosted models) ---
OLLAMA_BASE=http://localhost:11434

# --- Active Provider / Model (optional — can be changed in the UI) ---
ACTIVE_PROVIDER=groq
ACTIVE_MODEL=

# --- CORS (comma-separated origins; empty = allow all) ---
ALLOWED_ORIGINS=

# --- Rate Limiting ---
RATELIMIT_STORAGE_URL=memory://

# --- File Workspace ---
WORKSPACE_DIR=./workspace

# --- GitHub Integration ---
GITHUB_TOKEN=

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=

# --- MCP Tool Servers (optional, JSON array) ---
MCP_SERVERS=[]

# --- Database (optional — falls back to SQLite in-memory if unset) ---
DATABASE_URL=

# --- Supabase (optional, for persistent RAG/storage) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Logging ---
LOG_LEVEL=INFO
